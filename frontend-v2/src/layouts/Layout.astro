---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
}

const { title, description, lang } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth scroll-pt-24">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- SEO & Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/og-image.jpg" />
    
    <!-- i18n Alternate Links -->
    <link rel="alternate" hreflang="es" href={`${Astro.site || ''}/es`} />
    <link rel="alternate" hreflang="en" href={`${Astro.site || ''}/en`} />
    <link rel="alternate" hreflang="x-default" href={`${Astro.site || ''}/es`} />

    <!-- Theme Manager -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.add('light');
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <header class="border-b border-border-base bg-bg-base/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/opita-code-horizontal-black-v4.png" alt="Opita Code" class="h-8 w-auto object-contain shrink-0 dark:hidden" />
          <img src="/opita-code-horizontal-white-v4.png" alt="Opita Code" class="h-8 w-auto object-contain shrink-0 hidden dark:block" />
        </div>
        <nav class="hidden md:flex gap-8 text-sm font-medium items-center">
          <a href={`/${lang}#ecosystem`} class="text-text-muted hover:text-text-base transition-colors">{lang === 'es' ? 'Ecosistema' : 'Ecosystem'}</a>
          <a href={`/${lang}#about`} class="text-text-muted hover:text-text-base transition-colors">{lang === 'es' ? 'Nosotros' : 'About'}</a>
          <a href={`/${lang}#contact`} class="text-text-muted hover:text-text-base transition-colors">{lang === 'es' ? 'Contacto' : 'Contact'}</a>
          <div class="h-4 w-px bg-border-base"></div>
          <a href={`/${lang}/projects`} class="text-corporate-600 dark:text-corporate-400 hover:text-corporate-900 dark:hover:text-corporate-300 font-bold transition-colors">{lang === 'es' ? 'Portal de Clientes' : 'Client Portal'}</a>
        </nav>
        <div class="flex items-center gap-4">
          <div class="text-xs font-mono bg-bg-muted px-2 py-1 rounded text-text-muted border border-border-base flex items-center h-full">
            <a href="/es" class={lang === 'es' ? 'font-bold text-text-base' : ''}>ES</a>
            <span class="opacity-50 mx-1">/</span>
            <a href="/en" class={lang === 'en' ? 'font-bold text-text-base' : ''}>EN</a>
          </div>
          <ThemeToggle />
        </div>
      </div>
    </header>
    
    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-bg-muted border-t border-border-base py-12 mt-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-3">
          <img src="/opita-code-symbol-black-v4.png" alt="Opita Code" class="h-6 w-auto object-contain shrink-0 opacity-50 grayscale dark:hidden" />
          <img src="/opita-code-symbol-white-v4.png" alt="Opita Code" class="h-6 w-auto object-contain shrink-0 opacity-50 grayscale hidden dark:block" />
          <span class="text-sm text-text-muted font-medium">© {new Date().getFullYear()} Opita Code.</span>
        </div>
        <div class="text-sm text-corporate-700">
          {lang === 'es' ? 'Software práctico para negocios reales. Hecho en Colombia 🇨🇴' : 'Practical software for real businesses. Made in Colombia 🇨🇴'}
        </div>
      </div>
    </footer>
  </body>
</html>
